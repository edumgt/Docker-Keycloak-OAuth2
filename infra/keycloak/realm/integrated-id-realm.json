{
  "realm": "integrated-id",
  "enabled": true,
  "displayName": "Unified Auth Realm",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "roles": {
    "realm": [
      {
        "name": "member"
      },
      {
        "name": "medical-user"
      }
    ]
  },
  "clients": [
    {
      "clientId": "be-client",
      "name": "Backend API Client",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "be-client-secret",
      "redirectUris": [
        "http://localhost:8000/*",
        "http://127.0.0.1:8000/*"
      ],
      "webOrigins": [
        "*"
      ],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true
    },
    {
      "clientId": "airflow-client",
      "name": "Airflow Client",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "airflow-client-secret",
      "redirectUris": [
        "http://localhost:8888/*",
        "http://127.0.0.1:8888/*"
      ],
      "webOrigins": [
        "*"
      ],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false
    }
  ],
  "users": [
    {
